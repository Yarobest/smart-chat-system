generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  LECTURER
  ADMIN
}

enum ConversationType {
  DIRECT
  GROUP
}

enum ConversationMemberRole {
  MEMBER
  ADMIN
  OWNER
}

enum Semester {
  SEMESTER_1
  SEMESTER_2
}

enum CourseOfferingStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         UserRole  @default(STUDENT)
  studentId    String?
  staffId      String?
  faculty      String?
  department   String?
  programme    String?
  yearGroup    String?
  awardType    String?
  avatarUrl    String?
  isOnline     Boolean   @default(false)
  lastSeenAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  sessions            AuthSession[]
  ownedConversations  Conversation[]       @relation("ConversationOwner")
  memberships         ConversationMember[]
  messages            Message[]
  courseOfferings     CourseOffering[]     @relation("CourseLecturer")

  @@index([role])
  @@index([email])
  @@index([studentId])
  @@index([staffId])
  @@index([faculty])
  @@index([department])
  @@index([programme])
  @@index([yearGroup])
  @@index([awardType])
}

model AuthSession {
  id               String    @id @default(cuid())
  userId           String
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Conversation {
  id        String           @id @default(cuid())
  type      ConversationType
  title     String?
  directKey String?          @unique
  courseKey String?
  courseCode String?
  courseName String?
  faculty   String?
  department String?
  programme String?
  yearGroup String?
  awardType String?
  ownerId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  owner   User?                @relation("ConversationOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members ConversationMember[]
  messages Message[]
  courseOffering CourseOffering?

  @@index([type])
  @@index([ownerId])
  @@index([courseKey])
  @@index([courseCode])
  @@index([programme])
  @@index([yearGroup])
  @@index([awardType])
}

model Course {
  id          String   @id @default(cuid())
  code        String
  name        String
  description String?
  creditHours Int?
  lecturerId  String?
  faculty     String?
  department  String?
  programme   String?
  awardType   String?
  yearGroup   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  offerings CourseOffering[]

  @@unique([code, programme, awardType, yearGroup])
  @@index([faculty])
  @@index([department])
  @@index([programme])
  @@index([awardType])
  @@index([yearGroup])
}

model AcademicSession {
  id           String   @id @default(cuid())
  academicYear String
  semester     Semester
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  offerings CourseOffering[]

  @@unique([academicYear, semester])
  @@index([isActive])
}

model CourseOffering {
  id                String               @id @default(cuid())
  courseId          String
  academicSessionId String
  lecturerId        String
  conversationId    String?              @unique
  faculty           String?
  department        String?
  programme         String?
  awardType         String?
  yearGroup         String?
  status            CourseOfferingStatus @default(ACTIVE)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  course          Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  academicSession AcademicSession  @relation(fields: [academicSessionId], references: [id], onDelete: Cascade)
  lecturer        User             @relation("CourseLecturer", fields: [lecturerId], references: [id], onDelete: Restrict)
  conversation    Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)

  @@unique([courseId, academicSessionId, faculty, department, programme, awardType, yearGroup])
  @@index([lecturerId])
  @@index([faculty])
  @@index([department])
  @@index([programme])
  @@index([awardType])
  @@index([yearGroup])
  @@index([status])
}

model ConversationMember {
  id             String                 @id @default(cuid())
  conversationId String
  userId         String
  role           ConversationMemberRole @default(MEMBER)
  joinedAt       DateTime               @default(now())
  lastReadAt     DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  text           String
  metadata       Json?
  editedAt       DateTime?
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}
